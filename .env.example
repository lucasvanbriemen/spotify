# Copy to .env and fill in real values. The Rails app reads these via dotenv.
# Primary database (the music app's MySQL/MariaDB database).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=music
DB_USERNAME=root
DB_PASSWORD=

# Separate database used by the test suite (Rails erases it on every run).
DB_DATABASE_TEST=music_test

# Local development only: auth token validated against login.ltvb.nl, used
# instead of the cookie/redirect flow.
DEV_TOKEN=
